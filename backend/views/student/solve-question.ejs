<%- include('../partials/header') %>

<a href="/student" class="back-link">&larr; Back to Dashboard</a>

<div class="split-layout">
    <!-- LEFT COLUMN -->
    <div class="card">
        <div class="card-body">
            <div style="display:flex; justify-content:space-between; align-items:start; margin-bottom:2rem;">
                <h3 style="margin:0; font-size:1.5rem; color:var(--dark);">
                    <%= problem.title %>
                </h3>

                <span class="badge <%= problem.difficulty.toLowerCase() %>">
                    <%= problem.difficulty %>
                </span>
            </div>

            <div class="mb-4">
                <h5 class="fw-bold mb-2">Description</h5>
                <p class="text-muted"><%= problem.description %></p>
            </div>

            <div class="mt-4" style="margin-top:2rem;">
                <h5 class="fw-bold mb-2">Schema :</h5>
                <div class="schema-block"><%= schema.schema_sql %></div>
            </div>
        </div>
    </div>

    <!-- RIGHT COLUMN -->
    <div style="display:flex; flex-direction:column; gap:2rem;">

        <!-- Editor -->
        <div class="card">
            <div class="card-header"
                 style="background:var(--dark); color:white; font-family:var(--font-mono);">
                SQL Query Editor
            </div>

            <div class="card-body" style="padding:0;">
                <form action="/student/problem/<%= problem.problem_id %>/run"
                      method="POST">

                    <textarea
                        name="query"
                        class="code-editor"
                        placeholder="-- Write your MySQL query here...
SELECT * FROM students;"><%= queryText %></textarea>

                    <div class="card-footer"
                         style="padding:1rem 1.5rem; display:flex; gap:10px; justify-content:flex-end;">

                        <button type="submit"
                                name="action"
                                value="run"
                                class="btn btn-outline">
                            Run Code
                        </button>

                        <button type="submit"
                                name="action"
                                value="submit"
                                class="btn btn-primary">
                            Submit Query
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Output -->
        <div class="output-container">

            <div class="card-header"
                 style="display:flex; justify-content:space-between; align-items:center;">

                <span>Execution Result</span>

                <div style="display:flex; gap:10px;">

                    <% if(error){ %>

                        <span class="badge"
                              style="background:red;color:white;">
                            Error
                        </span>

                    <% } else if(result){ %>

                        <span class="badge"
                              style="background:green;color:white;">
                            Executed
                        </span>

                    <% } %>

                    <% if(verdict){ %>

                        <% if(verdict === "Correct Answer"){ %>

                            <span class="badge"
                                  style="background:green;color:white;">
                                Correct
                            </span>

                        <% } else if(verdict === "Wrong Answer"){ %>

                            <span class="badge"
                                  style="background:red;color:white;">
                                Wrong
                            </span>

                        <% } else { %>

                            <span class="badge"
                                  style="background:orange;color:white;">
                                <%= verdict %>
                            </span>

                        <% } %>

                    <% } %>

                </div>
            </div>

            <% if(error){ %>

                <div style="padding:1rem; color:red;">
                    <%= error %>
                </div>

            <% } %>

            <% if(result && result.length > 0){ %>

                <table>
                    <thead>
                        <tr>
                            <% Object.keys(result[0]).forEach(col => { %>
                                <th><%= col %></th>
                            <% }) %>
                        </tr>
                    </thead>

                    <tbody>
                        <% result.forEach(row => { %>
                            <tr>
                                <% Object.values(row).forEach(val => { %>
                                    <td><%= val %></td>
                                <% }) %>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>

            <% } else if(result && result.length === 0 && !error){ %>

                <div style="padding:1rem;">
                    Query executed successfully. No rows returned.
                </div>

            <% } %>

            <div class="card-footer">
                Execution Time :
                <strong><%= executionTime %> ms</strong>
            </div>

        </div>
    </div>
</div>

<%- include('../partials/footer') %>